{
  "name": "zouroboros-tui",
  "version": "2.0.0",
  "description": "Terminal UI for Zouroboros - visual interface for memory, swarm, and configuration",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "zouroboros-tui": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "zouroboros-core": "workspace:*",
    "zouroboros-memory": "workspace:*",
    "zouroboros-swarm": "workspace:*",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "ink-select-input": "^5.0.0",
    "ink-text-input": "^5.0.0",
    "ink-spinner": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "zouroboros",
    "tui",
    "terminal-ui",
    "cli"
  ],
  "license": "MIT"
}
