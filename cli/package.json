{
  "name": "zouroboros-cli",
  "version": "2.0.0",
  "description": "Unified command-line interface for Zouroboros",
  "type": "module",
  "bin": {
    "zouroboros": "./bin/zouroboros"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zouroboros-core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "keywords": [
    "zouroboros",
    "cli",
    "ai",
    "memory",
    "swarm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marlandoj/zouroboros.git",
    "directory": "cli"
  }
}
